#!/usr/bin/env bash
# newapp-web <naam> [beschrijving] [opties...]
# Opent de Goosie Builder met het formulier vooringevuld.
#
# Gebruik:
#   newapp-web mijn-app "Een Nostr app die..."
#   newapp-web mijn-app "Maak de knoppen groter" --update
#   newapp-web mijn-app "Beschrijving" --login=guest-only --theme=light --color=#f59e0b
#
# Opties:
#   --update                                 forceer update-mode (app moet bestaan)
#   --login=both|extension-only|guest-only   (standaard: both)
#   --theme=dark|light|both                  (standaard: dark)
#   --color=#hexkleur                        (standaard: #6366f1)

NAME="$1"
DESC="${2:-Een Nostr app: $NAME}"

if [[ -z "$NAME" ]]; then
    echo "Gebruik: newapp-web <naam> [\"beschrijving\"] [--update] [--login=...] [--theme=...] [--color=...]"
    echo "  naam mag alleen a-z, 0-9 en - bevatten"
    exit 1
fi

if [[ "$NAME" =~ [^a-z0-9-] ]]; then
    echo "❌ Naam mag alleen a-z, 0-9 en - bevatten"
    exit 1
fi

# Standaardwaarden
LOGIN="both"
THEME="dark"
COLOR="#6366f1"
MODE=""

# Verwerk extra argumenten (vanaf $3)
for arg in "${@:3}"; do
    case "$arg" in
        --update)   MODE="update" ;;
        --login=*)  LOGIN="${arg#--login=}" ;;
        --theme=*)  THEME="${arg#--theme=}" ;;
        --color=*)  COLOR="${arg#--color=}" ;;
    esac
done

# Auto-detecteer update-mode als app-directory al bestaat
if [[ -z "$MODE" ]] && [[ -d "/var/www/goosielabs/apps/$NAME" ]]; then
    MODE="update"
fi

# URL-encode waarden
urlencode() {
    python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"
}

URL="https://goosielabs.com/apps/newapp/?name=${NAME}"
URL="${URL}&description=$(urlencode "$DESC")"
URL="${URL}&loginMethod=$(urlencode "$LOGIN")"
URL="${URL}&theme=$(urlencode "$THEME")"
URL="${URL}&primaryColor=$(urlencode "$COLOR")"

if [[ "$MODE" == "update" ]]; then
    echo "✏️  Goosie Builder — update mode: $NAME"
    echo "   $DESC"
    KNOP="'Pas aan'"
else
    echo "🪿 Goosie Builder — nieuwe app: $NAME"
    echo "   $DESC"
    KNOP="'Bouw app'"
fi
echo "   login=$LOGIN  thema=$THEME  kleur=$COLOR"
echo ""
echo "👉 Open deze URL in je browser:"
echo "   $URL"
echo ""
echo "   Formulier is vooringevuld — klik op $KNOP als je klaar bent."
