# Skein Calendar API — service env
# Copy to .env in the same directory and fill in.

# Local bind port (nginx proxies /api/skein/calendar/* here).
PORT=3035

# Hex pubkey of the host. Incoming requests must carry a NIP-98 Authorization
# header signed by this pubkey (kind:27235 event, base64-encoded).
HOST_PUBKEY=a8364bf8e5b828bd722a6dc71882ff4ee8d379e64fbf4584f0c6f1b393f8058c

# Google OAuth (web client). See README.md for the one-off consent walkthrough.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Which calendar to write to. 'primary' targets the OAuthed user's main calendar.
GOOGLE_CALENDAR_ID=primary

# Whether to attach the guest as an attendee on insert.
# When true + the booking carries an email, Google emails the guest a calendar
# invite. Off by default — the guest's email is shared with Google as part of
# the event. Turn on per host preference.
ALLOW_ATTENDEES=false
