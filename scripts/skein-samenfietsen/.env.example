# Skein SamenFietsen poller — env
# Copy to .env in the same directory and fill in.

# --- SamenFietsen login ---
# SAFETY: the URLs below contain a BLOCK sentinel and a non-resolvable .invalid
# TLD. The poller hard-fails to run as long as the sentinel is present, so an
# accidental `systemctl enable --now` cannot reach the real SamenFietsen API.
# To actually use the poller: replace BLOCK-EDIT-BEFORE-USING.samenfietsen.invalid
# with the real samenfietsen.nl hostnames. MOCK_SF=1 bypasses this and uses
# fake data — handy for testing the publish path without touching SF.
SF_LOGIN_URL=https://BLOCK-EDIT-BEFORE-USING.samenfietsen.invalid/inloggen

# Perry's SamenFietsen credentials. The poller logs in 3x/day.
SF_EMAIL=
SF_PASSWORD=

# --- What to query ---
# Location to scope the trips() query to.
SF_LOCATION_ID=14a88b98-4bf0-4240-903e-17702ea98288

# Comma-separated bike ids to keep in the published event. Other bikes at
# the location are filtered out. List the fleet in priority order; the
# engine's pickBikeForSlot prefers earlier ids when both are free.
# Westerkim eerst, dan Elisabeth.
SF_BIKE_IDS=cff61909-3ab9-47d2-8c8d-2359a600a6c5,REPLACE_WITH_ELISABETH_SF_ID

# GraphQL endpoint. Same BLOCK sentinel — edit before enabling.
SF_GRAPHQL=https://BLOCK-EDIT-BEFORE-USING.samenfietsen.invalid/graphql

# How many days to look ahead.
RANGE_DAYS=21

# --- Where to publish ---
RELAY_URL=wss://relay.goosielabs.com
SKEINY_KEY_PATH=/home/deploy/agents/skeiny/nostr-key.json

# --- Scheduler ---
RUNS_PER_DAY=3
WINDOW_START_HOUR=8
WINDOW_END_HOUR=22
TZ=Europe/Amsterdam
